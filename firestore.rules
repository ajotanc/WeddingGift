rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Tenants: public read for matching slugs, but only owner can create/edit
    match /tenants/{tenantId} {
      allow read: if true;
      allow write: if isAuthenticated() && request.auth.uid == tenantId;
    }

    // Products: public read, but only tenant owner can create/edit
    match /products/{productId} {
      allow read: if true;
      allow write: if isAuthenticated() && request.resource.data.tenantId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.tenantId == request.auth.uid;
    }

    // RSVP: guests can write, tenant owner can read/write
    match /rsvp/{rsvpId} {
      allow read: if isAuthenticated() && resource.data.tenantId == request.auth.uid;
      allow create: if true; // Public can RSVP
      allow update, delete: if isAuthenticated() && resource.data.tenantId == request.auth.uid;
    }

    // Messages: public read, guests can create, tenant owner can read/write
    match /messages/{messageId} {
      allow read: if true;
      allow create: if true; 
      allow update, delete: if isAuthenticated() && resource.data.tenantId == request.auth.uid;
    }

    // Guests collection (Auth details for attendees)
    match /guests/{guestId} {
      allow read, write: if isAuthenticated() && request.auth.uid == guestId;
    }
  }
}
